# Database
DATABASE_URL=postgresql://postgres@localhost:5432/bytesail

# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-random-64-character-secret-string-for-sessions!!
ENCRYPTION_KEY=change-me-32-char-encryption!!
BETTER_AUTH_URL=http://localhost:5173

# GitHub OAuth (optional, for GitHub login and repo access)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Dashboard URL (used for CORS trusted origins)
DASHBOARD_URL=http://localhost:5173

# Version (set automatically in Docker builds)
BYTESAIL_VERSION=dev
