{
	"slug": "gitea",
	"name": "Gitea",
	"description": "Lightweight self-hosted Git service",
	"icon": "☕",
	"category": "devtools",
	"services": [
		{
			"name": "gitea",
			"image": "gitea/gitea:latest",
			"port": 3000,
			"volumes": [
				{ "name": "data", "mountPath": "/data", "size": "20Gi" },
				{ "name": "config", "mountPath": "/etc/gitea", "size": "100Mi" }
			],
			"environment": {
				"GITEA__database__DB_TYPE": "postgres",
				"GITEA__database__HOST": "postgresql:5432",
				"GITEA__database__NAME": "{{GITEA_DB_NAME|default:gitea}}",
				"GITEA__database__USER": "{{GITEA_DB_USER|default:gitea}}",
				"GITEA__database__PASSWD": "{{GITEA_DB_PASSWORD|generate:password:24}}",
				"GITEA__server__ROOT_URL": "{{GITEA_ROOT_URL|default:http://localhost:3000}}",
				"GITEA__server__SSH_PORT": "2222"
			}
		},
		{
			"name": "postgresql",
			"image": "postgres:16-alpine",
			"port": 5432,
			"volumes": [{ "name": "pg-data", "mountPath": "/var/lib/postgresql/data", "size": "10Gi" }],
			"environment": {
				"POSTGRES_USER": "{{GITEA_DB_USER|default:gitea}}",
				"POSTGRES_PASSWORD": "{{GITEA_DB_PASSWORD|generate:password:24}}",
				"POSTGRES_DB": "{{GITEA_DB_NAME|default:gitea}}"
			}
		}
	],
	"form": [
		{
			"key": "GITEA_ROOT_URL",
			"label": "Root URL",
			"type": "text",
			"default": "http://localhost:3000",
			"required": true
		},
		{
			"key": "GITEA_DB_USER",
			"label": "Database Username",
			"type": "text",
			"default": "gitea",
			"required": true
		},
		{
			"key": "GITEA_DB_PASSWORD",
			"label": "Database Password",
			"type": "password",
			"default": "",
			"required": true
		},
		{
			"key": "GITEA_DB_NAME",
			"label": "Database Name",
			"type": "text",
			"default": "gitea",
			"required": true
		}
	]
}
