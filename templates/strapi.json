{
	"slug": "strapi",
	"name": "Strapi",
	"description": "Leading open source headless CMS",
	"icon": "🚀",
	"category": "cms",
	"services": [
		{
			"name": "strapi",
			"image": "node:18-alpine",
			"port": 1337,
			"volumes": [{ "name": "app", "mountPath": "/srv/app", "size": "5Gi" }],
			"command": "npx create-strapi-app@latest . --no-run && npm run develop",
			"environment": {
				"DATABASE_CLIENT": "postgres",
				"DATABASE_HOST": "postgresql",
				"DATABASE_PORT": "5432",
				"DATABASE_NAME": "{{DATABASE_NAME|default:strapi}}",
				"DATABASE_USERNAME": "{{DATABASE_USERNAME|default:strapi}}",
				"DATABASE_PASSWORD": "{{DATABASE_PASSWORD|generate:password:24}}",
				"APP_KEYS": "{{APP_KEYS|generate:password:24}}",
				"API_TOKEN_SALT": "{{API_TOKEN_SALT|generate:password:24}}",
				"ADMIN_JWT_SECRET": "{{ADMIN_JWT_SECRET|generate:password:24}}",
				"TRANSFER_TOKEN_SALT": "{{TRANSFER_TOKEN_SALT|generate:password:24}}",
				"JWT_SECRET": "{{JWT_SECRET|generate:password:24}}"
			}
		},
		{
			"name": "postgresql",
			"image": "postgres:16-alpine",
			"port": 5432,
			"volumes": [{ "name": "pg-data", "mountPath": "/var/lib/postgresql/data", "size": "10Gi" }],
			"environment": {
				"POSTGRES_USER": "{{DATABASE_USERNAME|default:strapi}}",
				"POSTGRES_PASSWORD": "{{DATABASE_PASSWORD|generate:password:24}}",
				"POSTGRES_DB": "{{DATABASE_NAME|default:strapi}}"
			}
		}
	],
	"form": [
		{
			"key": "DATABASE_USERNAME",
			"label": "Database Username",
			"type": "text",
			"default": "strapi",
			"required": true
		},
		{
			"key": "DATABASE_PASSWORD",
			"label": "Database Password",
			"type": "password",
			"default": "",
			"required": true
		},
		{
			"key": "DATABASE_NAME",
			"label": "Database Name",
			"type": "text",
			"default": "strapi",
			"required": true
		}
	]
}
