{
	"slug": "minio",
	"name": "MinIO",
	"description": "High-performance S3-compatible object storage",
	"icon": "🪣",
	"category": "storage",
	"services": [
		{
			"name": "minio",
			"image": "minio/minio:latest",
			"port": 9000,
			"ports": [9000, 9001],
			"command": "server /data --console-address :9001",
			"volumes": [{ "name": "data", "mountPath": "/data", "size": "50Gi" }],
			"environment": {
				"MINIO_ROOT_USER": "{{MINIO_ROOT_USER|default:minioadmin}}",
				"MINIO_ROOT_PASSWORD": "{{MINIO_ROOT_PASSWORD|generate:password:24}}"
			}
		}
	],
	"form": [
		{
			"key": "MINIO_ROOT_USER",
			"label": "Root Username",
			"type": "text",
			"default": "minioadmin",
			"required": true
		},
		{
			"key": "MINIO_ROOT_PASSWORD",
			"label": "Root Password",
			"type": "password",
			"default": "",
			"required": true
		}
	]
}
