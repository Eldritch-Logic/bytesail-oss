{
	"slug": "ghost",
	"name": "Ghost",
	"description": "Professional publishing platform for blogs and newsletters",
	"icon": "👻",
	"category": "cms",
	"services": [
		{
			"name": "ghost",
			"image": "ghost:5",
			"port": 2368,
			"volumes": [{ "name": "content", "mountPath": "/var/lib/ghost/content", "size": "5Gi" }],
			"environment": {
				"url": "{{GHOST_URL|default:http://localhost:2368}}",
				"database__client": "mysql",
				"database__connection__host": "mysql",
				"database__connection__port": "3306",
				"database__connection__user": "{{MYSQL_USER|default:ghost}}",
				"database__connection__password": "{{MYSQL_PASSWORD|generate:password:24}}",
				"database__connection__database": "{{MYSQL_DATABASE|default:ghost}}"
			}
		},
		{
			"name": "mysql",
			"image": "mysql:8",
			"port": 3306,
			"volumes": [{ "name": "mysql-data", "mountPath": "/var/lib/mysql", "size": "10Gi" }],
			"environment": {
				"MYSQL_ROOT_PASSWORD": "{{MYSQL_ROOT_PASSWORD|generate:password:24}}",
				"MYSQL_USER": "{{MYSQL_USER|default:ghost}}",
				"MYSQL_PASSWORD": "{{MYSQL_PASSWORD|generate:password:24}}",
				"MYSQL_DATABASE": "{{MYSQL_DATABASE|default:ghost}}"
			}
		}
	],
	"form": [
		{
			"key": "GHOST_URL",
			"label": "Site URL",
			"type": "text",
			"default": "http://localhost:2368",
			"required": true
		},
		{
			"key": "MYSQL_USER",
			"label": "Database Username",
			"type": "text",
			"default": "ghost",
			"required": true
		},
		{
			"key": "MYSQL_PASSWORD",
			"label": "Database Password",
			"type": "password",
			"default": "",
			"required": true
		},
		{
			"key": "MYSQL_DATABASE",
			"label": "Database Name",
			"type": "text",
			"default": "ghost",
			"required": true
		},
		{
			"key": "MYSQL_ROOT_PASSWORD",
			"label": "MySQL Root Password",
			"type": "password",
			"default": "",
			"required": true
		}
	]
}
